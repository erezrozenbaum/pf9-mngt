# pf9-ssh-credentials — SSH credentials for Node Logs
#
# This file is a TEMPLATE. The encrypted value shown is a placeholder.
# Generate your own SealedSecret with the real pf9 user password:
#
#   kubectl create secret generic pf9-ssh-credentials \
#     --namespace pf9-mngt \
#     --from-literal=password='<PF9_USER_PASSWORD>' \
#     --dry-run=client -o yaml \
#   | kubeseal --controller-namespace kube-system \
#              --controller-name sealed-secrets-controller \
#              --format yaml > pf9-ssh-credentials.yaml
#
# Then commit the resulting pf9-ssh-credentials.yaml to your private deploy
# repo (e.g. pf9-mngt-deploy/secrets/) and apply it:
#
#   kubectl apply -f pf9-ssh-credentials.yaml
#
# Also set in your private Helm values (values.prod.yaml):
#
#   api:
#     nodeLogSource: "ssh"
#     ssh:
#       user: cloud-kvm    # OS user you SSH to the KVM nodes with
#       port: "22"
#
---
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: pf9-ssh-credentials
  namespace: pf9-mngt
spec:
  encryptedData:
    password: <REPLACE_WITH_KUBESEAL_OUTPUT>
  template:
    metadata:
      name: pf9-ssh-credentials
      namespace: pf9-mngt
