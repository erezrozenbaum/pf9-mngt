# Environment files (contains credentials)
.env
.env.local
.env.*.local

# Secret files (contains passwords) — individual files are gitignored,
# but the README is tracked for documentation.
secrets/*
!secrets/README.md

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual environment
.venv/
venv/
ENV/

# Runtime state files (generated at runtime)
p9_rvtools_state.json
metrics_cache.json
monitoring/cache/metrics_cache.json
monitoring/cache/cpu_state.json
monitoring/cache/metrics_cache_*.json
monitoring/cache/cpu_state_*.json

# Excel/CSV exports (generated outputs)
*.xlsx
CSV_exports/
*_RVTools_*.xlsx
*_Snapshot_Compliance_*.xlsx

# RVTools output directories (local exports - never commit)
C:/Reports/
/Reports/
/reports/
reports/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.bak
*~
.DS_Store

# Internal planning documents (not for public repo)
_plans/
improvements_plan.md
docs_remediation_plan.md

# Logs
*.log
*.log.err
logs/

# Database files
*.db
*.sqlite
*.sqlite3

# Docker volumes and persistent data (contains real user data)
pgdata/
postgres_data/
pgadmin_data/
ldap_data/
ldap_config/
ldap_database/

# Uploaded branding assets (user-uploaded logos)
api/static/logo.*

# Node modules (for pf9-ui)
node_modules/
pf9-ui/dist/
pf9-ui/node_modules/

# Keep important JSON config files
!package.json
!tsconfig.json
!tsconfig.*.json
!snapshot_policy_rules.json
!eslint.config.js
RESUME_*.md
MIGRATION_PLANNER_PHASES.md


# Internal planning documents (not for public repo)
improvements_plan.md
RUNBOOKS_PLAN.md
create_releases.ps1
docs_remediation_plan.md

# TLS certificates - never commit private keys
nginx/certs/*.key
nginx/certs/*.crt
nginx/certs/*.pem
