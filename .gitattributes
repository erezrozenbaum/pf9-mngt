# Set default EOL normalization
* text=auto

# Shell scripts always use LF line endings
*.sh text eol=lf

# PowerShell scripts use CRLF on Windows checkout
*.ps1 text eol=crlf

# Python and config files use LF
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.conf text eol=lf
*.env text eol=lf

# Binary files — no EOL conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
